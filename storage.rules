rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Files are organized by resort: resorts/{resortId}/...
    match /resorts/{resortId}/{allPaths=**} {
      // Anyone can read images and public assets (website gallery, logos)
      allow read: if true;
      // Uploading/deleting files requires authentication
      allow write: if request.auth != null;
    }
    
    // Fallback rule for other paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
